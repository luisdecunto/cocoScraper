# Copy this file to .streamlit/secrets.toml and fill in values for local dev.
# On Streamlit Community Cloud, paste these key/values in the Secrets UI instead.

DB_HOST = "your-neon-or-cloud-host"
DB_PORT = "5432"
DB_NAME = "prices"
DB_USER = "your_db_user"
DB_PASS = "your_db_password"
DB_SSLMODE = "require"   # required for Neon; omit for local PostgreSQL
